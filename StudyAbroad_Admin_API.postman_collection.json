{
  "info": {
    "name": "StudyAbroad Admin API",
    "description": "API Documentation for StudyAbroad Admin Web App",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://study-abroad-cemc-admin.vercel.app"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "YOUR_JWT_TOKEN_HERE",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Login with email and password"
          }
        },
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"student@example.com\",\n  \"password\": \"securePassword123\",\n  \"confirmPassword\": \"securePassword123\",\n  \"name\": \"Nguyen Van Student\",\n  \"phoneNumber\": \"0909123456\",\n  \"idCardNumber\": \"123456789012\",\n  \"dob\": \"2006-01-01T00:00:00.000Z\",\n  \"gender\": \"MALE\",\n  \"addressLine\": \"123 Street\",\n  \"city\": \"Ho Chi Minh\",\n  \"district\": \"District 1\",\n  \"ward\": \"Ward 1\",\n  \"schoolName\": \"Canada International School\",\n  \"programName\": \"Computer Science\",\n  \"degreeType\": \"HIGHSCHOOL\",\n  \"certificateType\": \"IELTS\",\n  \"gradeType\": \"GPA\",\n  \"gradeScore\": \"3.5\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            },
            "description": "Register new student account"
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/reset-password",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "reset-password"]
            },
            "description": "Request password reset email"
          }
        },
        {
          "name": "New Password (with token)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"password\": \"newPassword123\",\n  \"confirmPassword\": \"newPassword123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/new-password/RESET_TOKEN",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "new-password", "RESET_TOKEN"]
            },
            "description": "Set new password with reset token"
          }
        },
        {
          "name": "Delete Account",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/auth/delete",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "delete"]
            },
            "description": "Delete current user account"
          }
        }
      ]
    },
