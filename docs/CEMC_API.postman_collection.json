      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"admin@cemc.com\",\n    \"password\": \"Test123456\"\n}"
            },
            "url": {
              "raw": "{{apiProduction}}/auth/login",
              "host": ["{{apiProduction}}"],
              "path": ["auth", "login"]
            },
            "description": "Login with email and password"
          },
          "response": []
        },
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"student@test.com\",\n    \"password\": \"Test123456\",\n    \"confirmPassword\": \"Test123456\",\n    \"name\": \"Nguyen Van A\",\n    \"gender\": \"MALE\",\n    \"dob\": \"2005-06-20\",\n    \"phoneNumber\": \"0909123457\",\n    \"idCardNumber\": \"123456789013\",\n    \"addressLine\": \"456 Student Ave\",\n    \"city\": \"Ho Chi Minh City\",\n    \"district\": \"District 1\",\n    \"ward\": \"Ward 1\",\n    \"schoolName\": \"University of Sydney\",\n    \"programName\": \"Computer Science\",\n    \"degreeType\": \"HIGHSCHOOL\",\n    \"certificateType\": \"IELTS\",\n    \"gradeType\": \"GPA\",\n    \"gradeScore\": \"8.5\"\n}"
            },
            "url": {
              "raw": "{{apiProduction}}/auth/register",
